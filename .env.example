# Anthropic API — required for relevance scoring and summarization
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# NewsAPI.org — optional second article source
# Free tier at https://newsapi.org/ (100 requests/day)
NEWSAPI_KEY=

# ── Legacy email digest (disabled by default — see config/settings.yaml email.enabled) ──
# Only needed if you flip email.enabled: true.
# For Gmail: use an App Password (https://myaccount.google.com/apppasswords)
# Requires 2FA enabled on your Google account
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
